          },
          "id": "f6a7b8c9-d0e1-2345-6789-fabcde123456",
          "name": "Telegram (Solo Texto - Fallback)",
          "type": "n8n-nodes-base.telegram",
          "typeVersion": 1.1,
          "position": [
            1450,
            400
          ],
          "credentials": {}
        },
