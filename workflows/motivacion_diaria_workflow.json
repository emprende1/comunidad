            },
            "options": {}
          },
          "id": "e4f5a6b7-c8d9-0123-4567-efabcd123457",
          "name": "Set (Respuesta Procesada)",
          "type": "n8n-nodes-base.set",
          "typeVersion": 1.1,
          "position": [
            1050,
            600
          ]
        },
        {
          "parameters": {
            "model": "gpt-3.5-turbo",
            "messages": {
              "message": [
                {
                  "role": "system",
                  "content": "Eres un asistente experto en productividad. Dada la siguiente respuesta de un usuario a su tarea/motivación del día, genera un mini plan de acción personalizado con 2-3 pasos claros y concisos para ayudarle a progresar o superar cualquier bloqueo. El plan debe ser práctico y motivador. Responde únicamente con el plan, sin frases introductorias ni despedidas."
                },
                {
                  "role": "user",
                  "content": "={{ $json.respuesta_usuario }}"
                }
              ]
            },
            "options": {}
          },
          "id": "f5a6b7c8-d9e0-1234-5678-fabcde123457",
          "name": "OpenAI (Genera Plan de Acción)",
          "type": "n8n-nodes-base.openAiChat",
          "typeVersion": 1,
          "position": [
            1250,
            600
          ],
          "credentials": {}
        },
        {
          "parameters": {
            "chatId": "={{ $('Telegram Trigger (Respuesta Usuario)').item.json.message.chat.id }}",
