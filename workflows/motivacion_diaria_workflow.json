              "columns": [
                {
                  "column": "Fecha",
                  "value": "={{ $now.toFormat('yyyy-MM-dd HH:mm:ss') }}"
                },
                {
                  "column": "Tarea",
                  "value": "={{ $('Set (Extrae JSON IA)').item.json.tarea_ia }}"
                },
                {
                  "column": "Categoria",
                  "value": "={{ $('Set (Extrae JSON IA)').item.json.categoria_ia }}"
                },
                {
                  "column": "Mensaje",
                  "value": "={{ $('Set (Extrae JSON IA)').item.json.mensaje_ia }}"
                },
                {
                  "column": "AudioGenerado",
                  "value": "={{ $('IF (¿Audio OK?)').branchIndex === 0 ? 'Sí' : 'No' }}"
                }
              ]
            }
          },
          "id": "a0b1c2d3-e4f5-6789-0123-456789abcdef",
          "name": "Airtable (Registro Diario)",
          "type": "n8n-nodes-base.airtableAppend",
