                  "value2": true
                }
              ]
            }
          },
          "id": "d4e5f6a7-b8c9-0123-4567-defabc123456",
          "name": "IF (¿Audio OK?)",
          "type": "n8n-nodes-base.if",
          "typeVersion": 1,
          "position": [
            1250,
            300
          ]
        },
        {
          "parameters": {
            "chatId": "",
            "text": "={{ $json.mensaje_ia }}\n\nTarea de hoy ({{ $json.categoria_ia }}): {{ $json.tarea_ia }}",
            "additionalFields": {
              "file": "data"
            }
          },
          "id": "e5f6a7b8-c9d0-1234-5678-efabcd123456",
          "name": "Telegram (Audio y Texto)",
          "type": "n8n-nodes-base.telegram",
          "typeVersion": 1.1,
          "position": [
            1450,
            200
          ],
